{
  "_meta": {
    "models": {
      "MetricaViewModel": "View-model UI que combina último Metric (backend) + MetricTypeInfo (catálogo) + campos UI computados (sparkline, delta formatado, fonte humanizada, categoria, ícone).",
      "MetricTypeInfo": "Catálogo de tipos de métrica vindo do backend (tabela metric_types). Tem id, value (estável), label, unit, dataType, compositeFields, normalMin/Max (faixa única, fallback), referenciaPorIdadeSexo (faixas estratificadas), fonteReferencia (ACSM/OMS/ADA/NSF/etc.), points.",
      "Metric": "Registro individual de medição. Backend envia value, compositeValues, measuredAt, source, deviceId. Aqui guardamos apenas o último em ultimo: Metric — sparkline é série derivada."
    },
    "relationships": [
      "MetricaViewModel.ultimo aponta pra Metric do backend",
      "MetricaViewModel.tipo é o MetricTypeInfo associado",
      "categoria é UI-only — derivada de tipo.value via convenção (composicao/cardio/atividade/sono/hidratacao/outros)",
      "fonte humaniza Metric.source + deviceId + measuredAt em string",
      "sparkline = N últimos values da série retornada por GET /metrics?metricTypeId=X"
    ]
  },

