{
  "_meta": {
    "models": {
      "UsuarioContexto": "Combina User do backend + cálculos UI (saudação dinâmica, streak, primeiroNome, frase IA contextual).",
      "User": "Auth/users module — id, email, name, image, role (FREE/REGULAR/PREMIUM/etc.), version, etc.",
      "PlanoHoje": "Embute PatientDiet (instância do plano alimentar) + array de RefeicaoHoje (PatientDietMeal + registrada).",
      "AnelCalorias": "Derivado de MealLog (consumido) + DashboardMetricsSummary.caloriesBurned (gasto).",
      "MiniStat": "id = MetricType.value (ex: 'weight', 'daily_steps'). Frontend resolve valor/delta via Metrics + período.",
      "Novidade": "Banner condicional. Quando tipo='analise-ia', insight aponta pro AIInsight do backend (dashboard module)."
    },
    "relationships": [
      "usuario.user é User do backend",
      "plano.diet é PatientDiet (com PatientDietMeal[])",
      "plano.refeicoes[].meal é PatientDietMeal individual + flag registrada (vem de MealLog)",
      "novidades[].insight é AIInsight quando tipo='analise-ia', null caso contrário",
      "anelCalorias é agregado computado no frontend a partir de Metrics + MealLogs",
      "miniStats[].id corresponde a MetricType.value pra navegação/lookup"
    ]
  },

